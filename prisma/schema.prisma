generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Роли пользователей
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}

enum Season {
  WINTER
  SPRING
  SUMMER
  AUTUMN
}

// Пользователь
model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String?
  avatar   String?
  role     Role    @default(USER)

  isVerified         Boolean @default(false)
  isTwoFactorEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  favorites Favorite[]
}

model Token {
  id String @id @default(uuid())

  email     String
  token     String    @unique
  type      TokenType
  expiresIn DateTime
}

// Автор
model Author {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  bio       String?  @db.Text // Биография автора
  birthYear Int?
  deathYear Int?
  image     String?
  createdAt DateTime @default(now())

  poems Poem[]
}

// Категория (направление поэзии)
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())

  poems Poem[] @relation("PoemCategories")
}

// Стихотворение
model Poem {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String   @db.Text
  description String?  @db.Text
  authorId    Int
  year        Int?
  videoUrl    String?
  views       Int      @default(0)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author     Author     @relation(fields: [authorId], references: [id])
  categories Category[] @relation("PoemCategories")
  comments   Comment[]
  favorites  Favorite[]
  holidays   Holiday[] @relation("HolidayPoems")

  @@index([authorId])
}


// Праздник
model Holiday {
  id String @id @default(uuid())

  name  String
  slug  String @unique
  day   Int
  month Int

  season      Season // Время года для фильтрации по слайдам
  image       String? // Картинка праздника (опционально)
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poems Poem[] @relation("HolidayPoems")

  @@unique([day, month, slug])
  @@index([month, day])
}

// Комментарий к стихотворению
model Comment {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  userId    Int
  poemId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@index([poemId])
  @@index([userId])
}

// Избранное
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  poemId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@unique([userId, poemId])
  @@index([userId])
  @@index([poemId])
}
