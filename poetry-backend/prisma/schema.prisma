generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Роли пользователей
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}

enum Season {
  WINTER
  SPRING
  SUMMER
  AUTUMN
}

// Пользователь
model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String?
  avatar   String?
  role     Role    @default(USER)

  isVerified         Boolean @default(false)
  isTwoFactorEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  favorites Favorite[]
  likes     Like[]
  tokens    Token[]
}

model Token {
  id    String @id @default(uuid())
  email String

  token String @unique

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  type      TokenType
  expiresIn DateTime
}

// Автор
model Author {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  bio       String?  @db.Text // Биография автора
  birthYear Int?
  deathYear Int?
  image     String?
  createdAt DateTime @default(now())

  poems Poem[]
}

// Категория (направление поэзии)
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())

  poems Poem[] @relation("PoemCategories")
}

// Стихотворение
model Poem {
  id          Int     @id @default(autoincrement())
  title       String
  slug        String  @unique
  content     String  @db.Text
  description String? @db.Text
  authorId    Int
  year        Int?
  videoUrl    String?

  views          Int @default(0)
  likesCount     Int @default(0)
  commentsCount  Int @default(0)
  favoritesCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author     Author     @relation(fields: [authorId], references: [id])
  categories Category[] @relation("PoemCategories")
  holidays   Holiday[]  @relation("HolidayPoems")

  favorites Favorite[]
  likes     Like[]
  comments  Comment[]

  @@index([authorId])
  @@index([likesCount])
  @@index([favoritesCount])
  @@index([likesCount, favoritesCount])
}

model Like {
  id Int @id @default(autoincrement())

  userId Int
  poemId Int

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  poem      Poem     @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@unique([userId, poemId])
  @@index([userId, createdAt])
  @@index([poemId, createdAt])
  @@index([poemId])
}

// Комментарий к стихотворению
model Comment {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  userId    Int
  poemId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parentId  Int? // 🔥 ВОТ ЭТО

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([poemId])
  @@index([userId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  poemId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@unique([userId, poemId])
  @@index([userId, createdAt])
  @@index([poemId, createdAt])
  @@index([userId])
  @@index([poemId])
}

model View {
  id     Int  @id @default(autoincrement())
  poemId Int
  userId Int?

  ip     String?
  ipHash String? // хэш IP для уникальности (sha256)

  date DateTime @default(now()) // дата просмотра (без времени, но используем DateTime)

  createdAt DateTime @default(now())

  @@unique([poemId, userId, date])
  @@unique([poemId, ipHash, date])
  @@index([poemId])
}

// Праздник
model Holiday {
  id String @id @default(uuid())

  name  String
  slug  String @unique
  day   Int
  month Int

  season      Season // Время года для фильтрации по слайдам
  image       String? // Картинка праздника (опционально)
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poems Poem[] @relation("HolidayPoems")

  @@unique([day, month, slug])
  @@index([month, day])
}

// Избранное

// Слайды сезонов для главного слайдера
model SeasonSlide {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  season    Season
  imageUrl  String
  altText   String
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([season, order])
}
